# База данных PostgreSQL
DB_URL=postgres://veltrix:veltrix@localhost:5432/veltrix?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string

# Сервер
HTTP_ADDR=:8080
TLS_CERT_FILE=
TLS_KEY_FILE=

# CORS (пусто = разрешить любой origin — только для dev). Прод: https://app.example.com
# CORS_ALLOWED_ORIGINS=

# WebSocket Origin (пусто = как CORS). Прод: тот же origin, что у веб-клиента
# WS_ALLOWED_ORIGINS=

# Админы (UUID пользователей): только они могут делать глобальный бан/разбан и другие admin-операции
# ADMIN_USER_IDS=

# Федерация
NODE_DOMAIN=localhost
NODE_PRIVATE_KEY=
