## Zenthril client env (Vite)
# Copy to `client/.env` for local dev.
#
# Публичный хостинг: при сборке (`npm run build`) укажите URL API **без** завершающего слэша.
# Пример: VITE_API_BASE=https://api.example.com
# Тогда fetch и WebSocket (wss) пойдут на этот host. Локально можно не задавать — будет текущий хост:8080.
# VITE_API_BASE=

# GIF providers (optional). If empty, GIF search/normalization via API is disabled,
# but you can still paste direct GIF/image URLs.
VITE_TENOR_KEY=
VITE_GIPHY_KEY=

